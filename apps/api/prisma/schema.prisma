generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Branch {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  isWarehouse Boolean  @default(false) @map("is_warehouse")
  createdAt   DateTime @default(now()) @map("created_at")
  users       User[]

  stockLevels     StockLevel[]
  stockMovements  StockMovement[]
  transfersFrom   Transfer[]       @relation("TransferFrom")
  transfersTo     Transfer[]       @relation("TransferTo")
  sales           Sale[]
  numberSequences NumberSequence[]
  quotations      Quotation[]
  deliveryTeams   DeliveryTeam[]
  zReports        ZReport[]
  purchaseOrders  PurchaseOrder[]
  salesOrders     SalesOrder[]

  @@map("branches")
}

model Role {
  id                 Int      @id @default(autoincrement())
  key                String   @unique
  name               String
  isBranchScoped     Boolean  @default(false) @map("is_branch_scoped")
  discountMaxPercent Int?     @map("discount_max_percent")
  createdAt          DateTime @default(now()) @map("created_at")

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id          Int    @id @default(autoincrement())
  key         String @unique
  description String

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       Int @map("role_id")
  permissionId Int @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id                 Int      @id @default(autoincrement())
  username           String   @unique
  passwordHash       String   @map("password_hash")
  name               String
  roleId             Int      @map("role_id")
  branchId           Int?     @map("branch_id")
  isActive           Boolean  @default(true) @map("is_active")
  mustChangePassword Boolean  @default(true) @map("must_change_password")
  createdAt          DateTime @default(now()) @map("created_at")

  role     Role      @relation(fields: [roleId], references: [id])
  branch   Branch?   @relation(fields: [branchId], references: [id])
  sessions Session[]

  stockMovements        StockMovement[]
  transfers             Transfer[]
  pointTransactions     PointTransaction[]
  salesRung             Sale[]                  @relation("SaleCashier")
  salesVoided           Sale[]                  @relation("SaleVoidedBy")
  quotationsCreated     Quotation[]
  deliveryStatusChanges DeliveryStatusHistory[]
  zReportsGenerated     ZReport[]
  auditLogs             AuditLog[]
  purchaseOrders        PurchaseOrder[]
  salesOrdersCreated       SalesOrder[] @relation("SalesOrderCreatedBy")
  salesOrdersAsSalesperson SalesOrder[] @relation("SalesOrderSalesperson")

  @@map("users")
}

enum StockMovementReason {
  ADJUST
  TRANSFER_IN
  TRANSFER_OUT
  IMPORT
  SALE
  REFUND
  PO_RECEIVE
  SO_RESERVE
  SO_RELEASE
  SO_DELIVERY
}

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("categories")
}

model Product {
  id         Int      @id @default(autoincrement())
  sku        String   @unique
  name       String
  categoryId Int      @map("category_id")
  basePrice  Int      @map("base_price")
  isSofa     Boolean  @default(false) @map("is_sofa")
  isActive   Boolean  @default(true) @map("is_active")
  imageUrl   String?  @map("image_url")
  createdAt  DateTime @default(now()) @map("created_at")

  category       Category            @relation(fields: [categoryId], references: [id])
  stockLevels    StockLevel[]
  stockMovements StockMovement[]
  transfers      Transfer[]
  saleItems      SaleItem[]
  quotationItems QuotationItem[]
  poItems        PurchaseOrderItem[]
  soItems        SalesOrderItem[]

  @@map("products")
}

model SofaMaterial {
  id                 Int    @id @default(autoincrement())
  key                String @unique
  name               String
  priceMultiplierPct Int    @map("price_multiplier_pct")

  colors SofaColor[]

  @@map("sofa_materials")
}

model SofaColor {
  id         Int    @id @default(autoincrement())
  materialId Int    @map("material_id")
  name       String

  material SofaMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("sofa_colors")
}

model StockLevel {
  productId   Int @map("product_id")
  branchId    Int @map("branch_id")
  quantity    Int @default(0)
  reservedQty Int @default(0) @map("reserved_qty")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([productId, branchId])
  @@map("stock_levels")
}

model StockMovement {
  id              Int                 @id @default(autoincrement())
  productId       Int                 @map("product_id")
  branchId        Int                 @map("branch_id")
  delta           Int
  reason          StockMovementReason
  note            String?
  userId          Int?                @map("user_id")
  transferId      Int?                @map("transfer_id")
  saleId          Int?                @map("sale_id")
  purchaseOrderId Int?                @map("purchase_order_id")
  salesOrderId    Int?                @map("sales_order_id")
  createdAt       DateTime            @default(now()) @map("created_at")

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  branch        Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  user          User?          @relation(fields: [userId], references: [id])
  transfer      Transfer?      @relation(fields: [transferId], references: [id])
  sale          Sale?          @relation(fields: [saleId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  salesOrder    SalesOrder?    @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)

  @@map("stock_movements")
}

model Transfer {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  fromBranchId Int      @map("from_branch_id")
  toBranchId   Int      @map("to_branch_id")
  quantity     Int
  note         String?
  userId       Int?     @map("user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  product    Product         @relation(fields: [productId], references: [id])
  fromBranch Branch          @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch          @relation("TransferTo", fields: [toBranchId], references: [id])
  user       User?           @relation(fields: [userId], references: [id])
  movements  StockMovement[]

  @@map("transfers")
}

enum PointTransactionReason {
  EARN
  REDEEM
  ADJUST
  REFUND
}

model Customer {
  id              Int          @id @default(autoincrement())
  name            String
  phone           String       @unique
  phone2          String?
  email           String?
  taxId           String?      @map("tax_id")
  taxName         String?      @map("tax_name")
  taxAddress      String?      @map("tax_address")
  billingType     BillingType? @map("billing_type")
  billingBranchNo String?      @map("billing_branch_no")
  addrLine1       String?      @map("addr_line1")
  addrMoo         String?      @map("addr_moo")
  addrSoi         String?      @map("addr_soi")
  addrStreet      String?      @map("addr_street")
  addrKwang       String?      @map("addr_kwang")
  addrDistrict    String?      @map("addr_district")
  addrProvince    String?      @map("addr_province")
  addrPostal      String?      @map("addr_postal")
  pointsBalance   Int          @default(0) @map("points_balance")
  lifetimeSpend   Int          @default(0) @map("lifetime_spend")
  createdAt       DateTime     @default(now()) @map("created_at")

  pointTransactions PointTransaction[]
  sales             Sale[]
  quotations        Quotation[]
  salesOrders       SalesOrder[]

  @@map("customers")
}

model Supplier {
  id          Int      @id @default(autoincrement())
  name        String
  contactName String?  @map("contact_name")
  phone       String?
  email       String?
  address     String?
  taxId       String?  @map("tax_id")
  notes       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  purchaseOrders PurchaseOrder[]

  @@map("suppliers")
}

enum PurchaseOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id           Int                 @id @default(autoincrement())
  code         String              @unique
  supplierId   Int                 @map("supplier_id")
  branchId     Int                 @map("branch_id")
  status       PurchaseOrderStatus @default(DRAFT)
  orderDate    DateTime            @default(now()) @map("order_date")
  expectedDate DateTime?           @map("expected_date")
  receivedDate DateTime?           @map("received_date")
  subtotal     Int                 @default(0)
  vatAmount    Int                 @default(0) @map("vat_amount")
  totalAmount  Int                 @default(0) @map("total_amount")
  notes        String?
  createdById  Int                 @map("created_by_id")
  createdAt    DateTime            @default(now()) @map("created_at")

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  branch    Branch              @relation(fields: [branchId], references: [id])
  createdBy User                @relation(fields: [createdById], references: [id])
  items     PurchaseOrderItem[]
  movements StockMovement[]

  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              Int @id @default(autoincrement())
  purchaseOrderId Int @map("purchase_order_id")
  productId       Int @map("product_id")
  orderedQty      Int @map("ordered_qty")
  receivedQty     Int @default(0) @map("received_qty")
  unitCost        Int @map("unit_cost")
  lineTotal       Int @map("line_total")

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("purchase_order_items")
}

model PoSequence {
  year Int @id
  next Int @default(1)

  @@map("po_sequences")
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum BillingType {
  HEAD_OFFICE
  BRANCH
}

enum SoDeliveryType {
  COMPANY
  SELF_PICKUP
  OTHER
}

enum PaymentTerm {
  DEPOSIT
  FULL
  INSTALLMENT
}

enum PaymentMethodKind {
  CASH
  TRANSFER
  CREDIT_CARD
}

enum CardType {
  VISA
  MASTERCARD
  OTHER
}

model SalesOrder {
  id                 Int              @id @default(autoincrement())
  code               String           @unique
  customerId         Int?             @map("customer_id")
  branchId           Int              @map("branch_id")
  status             SalesOrderStatus @default(DRAFT)
  orderDate          DateTime         @default(now()) @map("order_date")
  dueDate            DateTime?        @map("due_date")
  deliveredDate      DateTime?        @map("delivered_date")
  subtotal           Int              @default(0)
  discount           Int              @default(0)
  vatAmount          Int              @default(0) @map("vat_amount")
  totalAmount        Int              @default(0) @map("total_amount")
  deposit            Int              @default(0)
  notes              String?
  quotationId        Int?             @map("quotation_id")
  poRef              String?          @map("po_ref")
  createdById        Int              @map("created_by_id")
  salespersonId      Int?             @map("salesperson_id")
  createdAt          DateTime         @default(now()) @map("created_at")

  bookNo             String?            @map("book_no")
  billingType        BillingType?       @map("billing_type")
  billingBranchNo    String?            @map("billing_branch_no")
  customerPhone2     String?            @map("customer_phone2")
  addrLine1          String?            @map("addr_line1")
  addrMoo            String?            @map("addr_moo")
  addrSoi            String?            @map("addr_soi")
  addrStreet         String?            @map("addr_street")
  addrKwang          String?            @map("addr_kwang")
  addrDistrict       String?            @map("addr_district")
  addrProvince       String?            @map("addr_province")
  addrPostal         String?            @map("addr_postal")
  canShipImmediately Boolean            @default(false) @map("can_ship_immediately")
  deliveryType       SoDeliveryType?    @map("delivery_type")
  deliveryTypeOther  String?            @map("delivery_type_other")
  deliveryInfo       Json?              @map("delivery_info")
  paymentTerm        PaymentTerm?       @map("payment_term")
  installmentMonths  Int?               @map("installment_months")
  depositMethod      PaymentMethodKind? @map("deposit_method")
  depositCardType    CardType?          @map("deposit_card_type")
  balanceMethod      PaymentMethodKind? @map("balance_method")
  balanceCardType    CardType?          @map("balance_card_type")

  customer    Customer?        @relation(fields: [customerId], references: [id])
  branch      Branch           @relation(fields: [branchId], references: [id])
  quotation   Quotation?       @relation(fields: [quotationId], references: [id])
  createdBy   User             @relation("SalesOrderCreatedBy", fields: [createdById], references: [id])
  salesperson User?            @relation("SalesOrderSalesperson", fields: [salespersonId], references: [id])
  items       SalesOrderItem[]
  movements   StockMovement[]

  @@map("sales_orders")
}

model SalesOrderItem {
  id           Int     @id @default(autoincrement())
  salesOrderId Int     @map("sales_order_id")
  productId    Int     @map("product_id")
  quantity     Int
  unitPrice    Int     @map("unit_price")
  discount     Int     @default(0)
  lineTotal    Int     @map("line_total")
  size         String?
  materials    String?
  color        String?

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@map("sales_order_items")
}

model SoSequence {
  year Int @id
  next Int @default(1)

  @@map("so_sequences")
}

model PointTransaction {
  id         Int                    @id @default(autoincrement())
  customerId Int                    @map("customer_id")
  delta      Int
  reason     PointTransactionReason
  note       String?
  userId     Int?                   @map("user_id")
  saleId     Int?                   @map("sale_id")
  createdAt  DateTime               @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id])
  sale     Sale?    @relation(fields: [saleId], references: [id])

  @@map("point_transactions")
}

enum SaleStatus {
  COMPLETED
  VOIDED
}

enum QuotationStatus {
  OPEN
  CONVERTED
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
}

enum TaxInvoiceType {
  ABBREVIATED
  FULL
}

model NumberSequence {
  id       Int    @id @default(autoincrement())
  branchId Int    @map("branch_id")
  kind     String
  next     Int    @default(1)

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, kind])
  @@map("number_sequences")
}

model Sale {
  id             Int        @id @default(autoincrement())
  number         String     @unique
  branchId       Int        @map("branch_id")
  customerId     Int?       @map("customer_id")
  cashierId      Int        @map("cashier_id")
  status         SaleStatus @default(COMPLETED)
  subtotal       Int
  discountAmount Int        @default(0) @map("discount_amount")
  pointsRedeemed Int        @default(0) @map("points_redeemed")
  total          Int
  outstanding    Int        @default(0)
  taxBase        Int        @map("tax_base")
  vatAmount      Int        @map("vat_amount")
  pointsEarned   Int        @default(0) @map("points_earned")
  voidReason     String?    @map("void_reason")
  voidedById     Int?       @map("voided_by_id")
  voidedAt       DateTime?  @map("voided_at")
  createdAt      DateTime   @default(now()) @map("created_at")

  branch            Branch             @relation(fields: [branchId], references: [id])
  customer          Customer?          @relation(fields: [customerId], references: [id])
  cashier           User               @relation("SaleCashier", fields: [cashierId], references: [id])
  voidedBy          User?              @relation("SaleVoidedBy", fields: [voidedById], references: [id])
  items             SaleItem[]
  payments          Payment[]
  taxInvoice        TaxInvoice?
  stockMovements    StockMovement[]
  pointTransactions PointTransaction[]
  fromQuotation     Quotation?
  delivery          Delivery?

  @@map("sales")
}

model Quotation {
  id              Int             @id @default(autoincrement())
  number          String          @unique
  branchId        Int             @map("branch_id")
  customerId      Int?            @map("customer_id")
  createdById     Int             @map("created_by_id")
  status          QuotationStatus @default(OPEN)
  subtotal        Int
  note            String?
  convertedSaleId Int?            @unique @map("converted_sale_id")
  createdAt       DateTime        @default(now()) @map("created_at")

  branch        Branch          @relation(fields: [branchId], references: [id])
  customer      Customer?       @relation(fields: [customerId], references: [id])
  createdBy     User            @relation(fields: [createdById], references: [id])
  convertedSale Sale?           @relation(fields: [convertedSaleId], references: [id])
  items         QuotationItem[]
  salesOrders   SalesOrder[]

  @@map("quotations")
}

model QuotationItem {
  id          Int    @id @default(autoincrement())
  quotationId Int    @map("quotation_id")
  productId   Int    @map("product_id")
  productName String @map("product_name")
  unitPrice   Int    @map("unit_price")
  quantity    Int
  lineTotal   Int    @map("line_total")

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id])

  @@map("quotation_items")
}

model SaleItem {
  id          Int    @id @default(autoincrement())
  saleId      Int    @map("sale_id")
  productId   Int    @map("product_id")
  productName String @map("product_name")
  unitPrice   Int    @map("unit_price")
  quantity    Int
  lineTotal   Int    @map("line_total")

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model Payment {
  id     Int           @id @default(autoincrement())
  saleId Int           @map("sale_id")
  method PaymentMethod
  amount Int

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model TaxInvoice {
  id                 Int            @id @default(autoincrement())
  saleId             Int            @unique @map("sale_id")
  type               TaxInvoiceType
  customerTaxId      String?        @map("customer_tax_id")
  customerTaxName    String?        @map("customer_tax_name")
  customerTaxAddress String?        @map("customer_tax_address")
  createdAt          DateTime       @default(now()) @map("created_at")

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("tax_invoices")
}

model AppSetting {
  key   String @id
  value String

  @@map("app_settings")
}

model Session {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique @map("token_hash")
  userId    Int      @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

enum DeliveryChannelType {
  IN_HOUSE
  COURIER
}

enum DeliveryStatus {
  PENDING
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  FAILED
  CANCELLED
}

model DeliveryZone {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  fee       Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  deliveries Delivery[]

  @@map("delivery_zones")
}

model DeliveryChannel {
  id        Int                 @id @default(autoincrement())
  name      String              @unique
  type      DeliveryChannelType
  createdAt DateTime            @default(now()) @map("created_at")

  deliveries Delivery[]

  @@map("delivery_channels")
}

model DeliveryTeam {
  id        Int      @id @default(autoincrement())
  name      String
  branchId  Int      @map("branch_id")
  createdAt DateTime @default(now()) @map("created_at")

  branch     Branch     @relation(fields: [branchId], references: [id])
  drivers    Driver[]
  deliveries Delivery[]

  @@map("delivery_teams")
}

model Driver {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  teamId    Int      @map("team_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  team       DeliveryTeam @relation(fields: [teamId], references: [id])
  deliveries Delivery[]

  @@map("drivers")
}

model Delivery {
  id             Int            @id @default(autoincrement())
  saleId         Int            @unique @map("sale_id")
  zoneId         Int            @map("zone_id")
  channelId      Int            @map("channel_id")
  teamId         Int?           @map("team_id")
  driverId       Int?           @map("driver_id")
  status         DeliveryStatus @default(PENDING)
  scheduledDate  DateTime       @map("scheduled_date")
  timeSlot       String?        @map("time_slot")
  addressText    String         @map("address_text")
  recipientName  String?        @map("recipient_name")
  recipientPhone String?        @map("recipient_phone")
  fee            Int            @default(0)
  note           String?
  createdAt      DateTime       @default(now()) @map("created_at")

  sale    Sale                    @relation(fields: [saleId], references: [id])
  zone    DeliveryZone            @relation(fields: [zoneId], references: [id])
  channel DeliveryChannel         @relation(fields: [channelId], references: [id])
  team    DeliveryTeam?           @relation(fields: [teamId], references: [id])
  driver  Driver?                 @relation(fields: [driverId], references: [id])
  history DeliveryStatusHistory[]

  @@map("deliveries")
}

model DeliveryStatusHistory {
  id          Int            @id @default(autoincrement())
  deliveryId  Int            @map("delivery_id")
  status      DeliveryStatus
  note        String?
  changedById Int?           @map("changed_by_id")
  createdAt   DateTime       @default(now()) @map("created_at")

  delivery  Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  changedBy User?    @relation(fields: [changedById], references: [id])

  @@map("delivery_status_history")
}

enum ReportChannel {
  EMAIL
  LINE
}

enum ReportSendStatus {
  SENT
  FAILED
  SKIPPED
}

model ZReport {
  id            Int      @id @default(autoincrement())
  branchId      Int      @map("branch_id")
  businessDate  DateTime @map("business_date") @db.Date
  generatedById Int      @map("generated_by_id")
  salesCount    Int      @map("sales_count")
  grossTotal    Int      @map("gross_total")
  vatTotal      Int      @map("vat_total")
  discountTotal Int      @map("discount_total")
  cashTotal     Int      @map("cash_total")
  transferTotal Int      @map("transfer_total")
  cardTotal     Int      @map("card_total")
  voidedCount   Int      @map("voided_count")
  voidedTotal   Int      @map("voided_total")
  createdAt     DateTime @default(now()) @map("created_at")

  branch      Branch @relation(fields: [branchId], references: [id])
  generatedBy User   @relation(fields: [generatedById], references: [id])

  @@unique([branchId, businessDate])
  @@map("z_reports")
}

model DailyReportHistory {
  id        Int              @id @default(autoincrement())
  channel   ReportChannel
  status    ReportSendStatus
  recipient String?
  content   String
  error     String?
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("daily_report_history")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  userId     Int?     @map("user_id")
  method     String
  path       String
  statusCode Int      @map("status_code")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_log")
}
